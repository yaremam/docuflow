# Copy to `.env` in this directory before `docker compose up -d`.

# ── Required: your host's LAN address ───────────────────────────────────
# Embedded in the phone-scan QR code, password-reset email links, and
# presigned blob URLs — all opened by browsers/phones OUTSIDE the Docker
# network, so `localhost` only works if you never leave this machine.
APP_BASE_URL=http://192.168.1.50:8080
BLOB_PUBLIC_ENDPOINT_URL=http://192.168.1.50:9000

# ── Required: credentials (pick your own) ───────────────────────────────
POSTGRES_PASSWORD=change-me-please
MINIO_PASSWORD=change-me-please
MINIO_USER=docuflow

# ── Optional: host-side ports (defaults shown) ──────────────────────────
# DSM claims 5000/5001 itself and some packages take 8080 — override here
# if a port is already busy on your NAS. If you change APP_PORT or
# MINIO_PORT, update APP_BASE_URL / BLOB_PUBLIC_ENDPOINT_URL to match.
#APP_PORT=8080
#MINIO_PORT=9000
#MAILPIT_UI_PORT=8025

# ── Optional: real email delivery (default: Mailpit, view at :8025,
# nothing actually delivered) ────────────────────────────────────────────
# Password-reset links are the only email this app sends. To have them
# actually delivered, set all six of these — no docker-compose.yml edits
# needed. SMTP_INSECURE=false is required for any real provider (it's
# only for Mailpit, which has no TLS at all):
#
#   SMTP_HOST      the provider's SMTP hostname
#   SMTP_PORT      587 (STARTTLS, most providers' documented default) or
#                  465 (implicit TLS) — port 465 is treated as implicit
#                  TLS, every other port as STARTTLS
#   SMTP_USERNAME  \ your provider's SMTP credentials — both or neither,
#   SMTP_PASSWORD  / never one without the other
#   SMTP_FROM      must be a sender address/domain your provider allows
#   SMTP_INSECURE  must be "false" (anything other than "true" works, but
#                  "false" is the clear choice) once using a real provider
#
# Worked example (SendGrid — smtp.sendgrid.net, username is literally
# "apikey", password is the API key itself, not your account password).
# Once you've confirmed delivery works, you can also delete the `mailpit`
# service block from docker-compose.yml and drop MAILPIT_UI_PORT above —
# nothing references it anymore:
#SMTP_HOST=smtp.sendgrid.net
#SMTP_PORT=587
#SMTP_USERNAME=apikey
#SMTP_PASSWORD=your-sendgrid-api-key
#SMTP_FROM=no-reply@your-domain.example
#SMTP_INSECURE=false
