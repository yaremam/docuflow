DATABASE_URL=postgres://admin:secretpassword@localhost:5432/doc_manager_db

# Optional — defaults to 8080 if unset. Override if that port is already
# taken on your machine.
# PORT=8080

# Trace export to the dev-stack Jaeger (`docker compose up -d jaeger`,
# UI at http://localhost:16686). Optional since feature 021: leave unset
# to run with stdout logs only and no OTel exporter at all — the mode a
# deployed image runs in.
OTLP_ENDPOINT=http://localhost:4317

# Blob storage (profile pictures, document uploads) — points at the MinIO
# service from docker-compose.yml for local dev (`docker compose up -d
# minio`; browse buckets at http://localhost:9001). Must be running for
# cargo run/cargo test to work.
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
BLOB_BUCKET_NAME=docuflow-uploads

# Only needed when running the app itself inside Docker Compose (where
# AWS_ENDPOINT_URL above is instead set to the internal `http://minio:9000`
# hostname) — presigned picture URLs must resolve from the user's browser,
# not from inside the Docker network. Not needed for host-side `cargo run`.
# BLOB_PUBLIC_ENDPOINT_URL=http://localhost:9000

# Password-reset emails — points at the Mailpit dev mail-catcher from
# docker-compose.yml (`docker compose up -d mailpit`); view sent emails at
# http://localhost:8025. SMTP_INSECURE=true is required for Mailpit, which
# speaks plaintext SMTP with no TLS — never set this for a real provider.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@docuflow.local
SMTP_INSECURE=true

# Base URL embedded in emailed password-reset links. Optional — defaults to
# http://localhost:8080 (matching the PORT default above) if unset.
# APP_BASE_URL=http://localhost:8080
